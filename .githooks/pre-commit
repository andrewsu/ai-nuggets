#!/usr/bin/env bash
# Reject commits that contain malformed feed.xml files.
#
# Triggered when any feed.xml under podcasts/ is staged. Validates the
# staged blob (not the working tree) for:
#   1. XML well-formedness — catches unescaped & and similar parse errors.
#   2. <pubDate> weekday matches the date — strict podcast clients (and
#      RFC 822) reject feeds whose weekday names disagree with the date.

set -e

HOOK_DIR=$(dirname "$0")

staged_feeds=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '(^|/)feed\.xml$' || true)

if [ -z "$staged_feeds" ]; then
  exit 0
fi

bad=0
for f in $staged_feeds; do
  if ! git show ":$f" | python3 "$HOOK_DIR/check-feed.py" "$f"; then
    bad=1
  fi
done

if [ $bad -ne 0 ]; then
  echo >&2
  echo "Fix the feed and re-stage. (Common fixes: escape & as &amp;; correct pubDate weekdays.)" >&2
  exit 1
fi
